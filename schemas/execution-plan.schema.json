{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FA Local Execution Plan",
  "description": "Bounded, inspectable, fingerprintable execution plan required before FA Local runtime coordination can exist.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_plan_id",
    "correlation_id",
    "originating_request_id",
    "steps",
    "referenced_capabilities",
    "declared_max_step_count",
    "declared_side_effect_classes",
    "fallback_references",
    "cancellation_policy",
    "completion_policy",
    "max_duration_budget_ms",
    "stable_plan_hash",
    "planned_at_utc"
  ],
  "properties": {
    "execution_plan_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "originating_request_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "referenced_capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/capability_id"
      }
    },
    "declared_max_step_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16
    },
    "declared_side_effect_classes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/side_effect_class"
      }
    },
    "fallback_references": {
      "type": "array",
      "minItems": 0,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/fallback_reference"
      }
    },
    "cancellation_policy": {
      "type": "string",
      "enum": [
        "cancel_remaining_steps",
        "finish_in_flight_only"
      ]
    },
    "completion_policy": {
      "type": "string",
      "enum": [
        "all_steps_must_succeed",
        "allow_declared_fallback_completion"
      ]
    },
    "max_duration_budget_ms": {
      "type": "integer",
      "minimum": 1,
      "maximum": 600000
    },
    "stable_plan_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "planned_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "capability_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "none",
        "local_file_write",
        "local_db_mutation",
        "local_process_spawn",
        "external_network_denied_by_default",
        "other_governed"
      ]
    },
    "step_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 48,
      "pattern": "^[a-z0-9][a-z0-9_-]{0,47}$"
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "capability_id",
        "declared_side_effect_class",
        "timeout_budget_ms"
      ],
      "properties": {
        "step_id": {
          "$ref": "#/$defs/step_id"
        },
        "capability_id": {
          "$ref": "#/$defs/capability_id"
        },
        "declared_side_effect_class": {
          "$ref": "#/$defs/side_effect_class"
        },
        "timeout_budget_ms": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        }
      }
    },
    "fallback_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "fallback_step_id"
      ],
      "properties": {
        "step_id": {
          "$ref": "#/$defs/step_id"
        },
        "fallback_step_id": {
          "$ref": "#/$defs/step_id"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "completion_policy": {
            "const": "all_steps_must_succeed"
          }
        }
      },
      "then": {
        "properties": {
          "fallback_references": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
