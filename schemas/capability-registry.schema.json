{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boswelldigitalsolutions.com/schemas/fa-local/capability-registry.schema.json",
  "title": "FA Local Capability Registry",
  "description": "Bounded capability registry for FA Local admission checks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_version",
    "capabilities"
  ],
  "$defs": {
    "uuid_string": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "requester_class": {
      "type": "string",
      "enum": [
        "trusted_app_surface",
        "trusted_internal_service",
        "review_surface",
        "development_test_surface",
        "untrusted_unknown"
      ]
    },
    "approval_posture": {
      "type": "string",
      "enum": [
        "denied",
        "review_required",
        "explicit_operator_approval",
        "policy_preapproved",
        "execute_allowed"
      ]
    },
    "side_effect_class": {
      "type": "string",
      "enum": [
        "none",
        "local_file_write",
        "local_db_mutation",
        "local_process_spawn",
        "external_network_denied_by_default",
        "other_governed"
      ]
    },
    "revocation_state": {
      "type": "string",
      "enum": [
        "active",
        "disabled",
        "revoked"
      ]
    }
  },
  "properties": {
    "registry_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capability_id",
          "owner_service",
          "capability_type",
          "side_effect_class",
          "approval_posture",
          "allowed_requester_classes",
          "timeout_budget_ms",
          "retry_budget",
          "max_duration_budget_ms",
          "enabled_state",
          "review_class",
          "provenance",
          "revocation_state"
        ],
        "properties": {
          "capability_id": {
            "allOf": [
              {
                "$ref": "#/$defs/uuid_string"
              }
            ]
          },
          "owner_service": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{1,63}$"
          },
          "capability_type": {
            "type": "string",
            "enum": [
              "local_file_write",
              "local_db_mutation",
              "local_process_spawn",
              "governed_other"
            ]
          },
          "side_effect_class": {
            "$ref": "#/$defs/side_effect_class"
          },
          "approval_posture": {
            "$ref": "#/$defs/approval_posture"
          },
          "allowed_requester_classes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "uniqueItems": true,
            "items": {
              "$ref": "#/$defs/requester_class"
            }
          },
          "timeout_budget_ms": {
            "type": "integer",
            "minimum": 1,
            "maximum": 300000
          },
          "retry_budget": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "max_duration_budget_ms": {
            "type": "integer",
            "minimum": 1,
            "maximum": 86400000
          },
          "max_cpu_budget": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100
          },
          "max_mem_budget_mb": {
            "type": "integer",
            "minimum": 16,
            "maximum": 65536
          },
          "enabled_state": {
            "type": "string",
            "enum": [
              "enabled",
              "disabled"
            ]
          },
          "review_class": {
            "type": "string",
            "enum": [
              "none",
              "operator"
            ]
          },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_kind",
              "issued_at"
            ],
            "properties": {
              "source_kind": {
                "type": "string",
                "enum": [
                  "registry_file"
                ]
              },
              "issued_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "revocation_state": {
            "$ref": "#/$defs/revocation_state"
          },
          "version_range": {
            "type": "string",
            "maxLength": 64
          }
        }
      }
    }
  }
}
